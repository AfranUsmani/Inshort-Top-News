<div class="empty">
    <div class="empty__emoji" aria-hidden="true">📰</div>
    <h2 class="empty__title">
        <% if (typeof query !== 'undefined' && query) { %>No results for "<%= query %>"<% } else { %>No stories right now<% } %>
