<a class="featured <%= article.urlToImage ? '' : 'featured--noimg' %>"
   href="<%= article.url %>" target="_blank" rel="noopener noreferrer"
   data-category="<%= article.category || 'Top' %>">
    <% if (article.urlToImage) { %>
    <div class="featured__media">
        <img src="<%= article.urlToImage %>" alt="" loading="eager">
        <span class="featured__flag">Top story</span>
    </div>
    <% } %>
    <div class="featured__body">
        <div class="featured__meta">
            <% if (article.category) { %><span class="pill pill--<%= article.category.toLowerCase() %>"><%= article.category %></span><% } %>
            <% if (article.source && article.source.name) { %><span class="card__source"><%= article.source.name %></span><% } %>
            <% if (typeof timeAgo === 'function' && article.publishedAt) { %><span class="card__time"><%= timeAgo(article.publishedAt) %></span><% } %>
        </div>
        <h2 class="featured__title"><%= article.title %></h2>
        <p class="featured__summary"><%= article.summary %></p>
        <span class="card__more">Read full story &rarr;</span>
    </div>
</a>
