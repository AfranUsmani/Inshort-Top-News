<section class="hero">
    <h1 class="hero__title">
        <% if (typeof query !== 'undefined' && query) { %>Results for &ldquo;<%= query %>&rdquo;<% } else { %>Top stories in India<% } %>
    </h1>
    <p class="hero__meta">
        <span class="dot" aria-hidden="true"></span>
        <%= articles.length %> stor<%= articles.length === 1 ? 'y' : 'ies' %> &middot; auto-summarized &middot; updated live
    </p>
</section>
