<section class="promo" aria-label="Newsletter signup">
    <div class="promo__text">
        <h2 class="promo__title">📬 The Daily In-Short</h2>
        <p class="promo__sub">Top headlines in your inbox, once a day. Free — no spam, unsubscribe anytime.</p>
    </div>
    <% if (typeof subscribed !== 'undefined' && subscribed) { %>
        <p class="promo__ok" role="status">✓ You&rsquo;re in! Check your inbox to confirm.</p>
    <% } else { %>
        <form class="promo__form" action="/subscribe" method="POST">
            <input class="promo__input" type="email" name="email" placeholder="you@example.com"
                   aria-label="Email address" required maxlength="200">
            <button class="promo__btn" type="submit">Subscribe</button>
        </form>
        <% if (typeof subscribeError !== 'undefined' && subscribeError) { %>
            <p class="promo__err" role="alert">
                <%= subscribeError === 'invalid' ? 'Please enter a valid email address.' : 'Something went wrong — please try again.' %>
            </p>
        <% } %>
    <% } %>
</section>
