# NewsAPI key — https://newsapi.org/register
API_KEY=YOUR_NEWSAPI_KEY_HERE

# Optional: enables AI-generated "in-short" summaries + briefing.
# https://console.anthropic.com — without it, the app shows source descriptions.
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY_HERE

# Optional: model for AI summaries. Defaults to claude-haiku-4-5 (fast/cheap).
# Set to claude-opus-4-8 for higher-quality summaries.
# AI_MODEL=claude-haiku-4-5
