# No API key required — news comes from Google News RSS (free, no key, live).

# Optional — port for local dev (defaults to 5000)
# PORT=5000

# Optional — newsletter signups POST here as {"email": "..."} when set.
# Use a Buttondown/Mailchimp/Formspree/Zapier webhook URL. If unset, signups
# are just logged to the server console.
# NEWSLETTER_WEBHOOK=https://your-provider.example/webhook
